# Loaded by Next.js when NODE_ENV=test (which also makes it skip .env.local —
# required: in this Next version .env.local overrides even real process env).
# Everything here is a public dummy for the Playwright smoke tests; no secrets.
TURSO_DATABASE_URL=file:./.e2e/e2e.db
TURSO_AUTH_TOKEN=
SESSION_SECRET=e2e-only-dummy-session-secret-32-chars!
# bcrypt hash of 'test-owner-password' — every $ must be \-escaped or
# Next's env loader expands "$2b" etc. as variables and mangles the value
OWNER_PASSWORD_HASH=\$2b\$10\$J60RgzVsPPVtF7zoEiealuJPA.6gghMy27/LFJWEwrCWhKipN.OKK
CRON_SECRET=e2e-dummy
PRICE_USD_TO_GBP=0.8
PRICE_EUR_TO_GBP=0.85
